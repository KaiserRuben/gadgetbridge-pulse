# Pulse — required environment variables
# Copy to .env.local (Next.js) and fill values. Server-only (do NOT prefix with NEXT_PUBLIC_).

# Path to the Syncthing-mirrored Gadgetbridge SQLite DB
GADGETBRIDGE_DB_PATH=/path/to/Gadgetbridge.db

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys --json`.
# Keep the private key secret. Public key is also exposed to the browser via the
# subscribe API, but it is fine to mirror it as NEXT_PUBLIC_VAPID_PUBLIC_KEY if
# the client needs it directly.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Single-writer guard for pulse.db. Set "writer" on the host that owns the
# Pi-served Next.js (typically the Pi); set "reader" on every other host
# (e.g. Mac dev) so getWritableDb() throws and accidental local writes are
# never persisted to that host's copy. Leaving this unset preserves the
# legacy permissive behaviour, but you almost certainly want "reader" on
# every machine that POSTs to a remote ingest URL.
PULSE_ROLE=reader
