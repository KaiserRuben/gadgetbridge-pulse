  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
