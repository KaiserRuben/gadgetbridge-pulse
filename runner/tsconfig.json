{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["../lib/*"]
    }
  },
  "include": ["src/**/*", "../lib/types/**/*"],
  "exclude": ["../lib/types/v3.ts"]
}
