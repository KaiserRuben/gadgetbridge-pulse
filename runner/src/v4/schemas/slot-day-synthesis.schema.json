{
  "$id": "slot-day-synthesis.schema.json",
  "title": "DaySynthesisPayload",
  "description": "End-of-day narrative composed from all 4 prior daily slots + tier1. Hard-dep on evening_review; soft-degrades when other priors are missing (status=degraded, narrative still produced from what's available).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "language",
    "incomplete",
    "abstain",
    "abstain_reason",
    "headline",
    "summary_short",
    "summary_long",
    "narrative",
    "top_anchors",
    "tomorrow_focus",
    "kpis",
    "confidence"
  ],
  "properties": {
    "schema_version": { "const": "day-synthesis/v1" },
    "language": { "enum": ["de", "en"] },
    "incomplete": { "type": "boolean" },
    "abstain": { "type": "boolean" },
    "abstain_reason": { "type": ["string", "null"] },
    "headline": { "type": ["string", "null"], "maxLength": 80 },
    "summary_short": { "type": ["string", "null"], "maxLength": 120 },
    "summary_long": { "type": ["string", "null"] },
    "narrative": {
      "type": ["string", "null"],
      "description": "Longer-form day story (≤600 chars). Must cite ≥3 distinct numbers covering at least: sleep, day activity, recovery."
    },
    "top_anchors": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reasoning", "signal", "takeaway"],
        "properties": {
          "reasoning": { "type": "string", "minLength": 20 },
          "signal": { "type": "string", "minLength": 4, "maxLength": 80 },
          "takeaway": { "type": "string", "minLength": 8, "maxLength": 160 }
        }
      }
    },
    "tomorrow_focus": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "One-sentence framing for tomorrow's morning_briefing to pick up."
    },
    "kpis": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "description": "First 3 in this exact order: day_score, balance, momentum.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reasoning", "id", "label_de", "value", "band"],
        "properties": {
          "reasoning": { "type": "string", "minLength": 20 },
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,40}$" },
          "label_de": { "type": "string", "minLength": 3, "maxLength": 40 },
          "value": { "type": "number", "minimum": 0, "maximum": 100 },
          "band": { "enum": ["above_usual", "steady", "below_usual"] }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "reasoning"],
      "properties": {
        "reasoning": { "type": "string", "minLength": 20 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
