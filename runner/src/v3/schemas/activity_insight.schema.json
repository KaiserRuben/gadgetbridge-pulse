{
  "$id": "activity_insight.schema.json",
  "title": "ActivityInsightV3",
  "description": "Activity use-case insight. Each prose field cites ≥1 concrete number from the package. KPI and suggestion items carry their own 'reasoning' first property.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "language",
    "incomplete",
    "abstain",
    "abstain_reason",
    "headline",
    "summary_short",
    "summary_long",
    "analysis_today",
    "analysis_context",
    "suggestions_today",
    "suggestions_long_term",
    "kpis",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "const": "use_case/activity/v1"
    },
    "language": {
      "enum": [
        "de",
        "en"
      ]
    },
    "incomplete": {
      "type": "boolean",
      "description": "Single completion flag. true = artifact still in-flight or failed validation. Flipped to false only by the writer as the very last step before atomic rename."
    },
    "abstain": {
      "type": "boolean"
    },
    "abstain_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "headline": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "summary_short": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120,
      "description": "Mobile summary, ≤120 chars. Must mention at least one concrete value (steps, workout, active_min)."
    },
    "summary_long": {
      "type": [
        "string",
        "null"
      ],
      "description": "Desktop summary, ≤200 chars. Must include at least one baseline/delta reference."
    },
    "analysis_today": {
      "type": [
        "string",
        "null"
      ],
      "description": "Concrete description of today's activity (workouts incl. type/duration/intensity/load, steps, active_min, sedentary_blocks). Must cite ≥2 numbers."
    },
    "analysis_context": {
      "type": [
        "string",
        "null"
      ],
      "description": "How today's load sits vs last 2 days AND vs 30d baseline. Must cite ≥1 z-score AND ≥1 short-term comparison."
    },
    "suggestions_today": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasoning",
          "anchor",
          "tiny",
          "why",
          "horizon"
        ],
        "properties": {
          "reasoning": {
            "type": "string",
            "minLength": 20,
            "description": "Why this action right now. Cite the signal."
          },
          "anchor": {
            "type": "string",
            "minLength": 4,
            "maxLength": 60,
            "description": "The signal (e.g. 'Sedentary 1087min, Steps 4.2k vs Median 8k'). NOT the action."
          },
          "tiny": {
            "type": "string",
            "minLength": 4,
            "maxLength": 80,
            "description": "The action, imperative, concrete."
          },
          "why": {
            "type": "string",
            "minLength": 8,
            "description": "Mechanism / expected benefit. Different from 'tiny'."
          },
          "horizon": {
            "enum": [
              "today",
              "tonight"
            ]
          }
        }
      }
    },
    "suggestions_long_term": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasoning",
          "horizon",
          "action",
          "why"
        ],
        "properties": {
          "reasoning": {
            "type": "string",
            "minLength": 20
          },
          "horizon": {
            "enum": [
              "this_week",
              "this_month"
            ]
          },
          "action": {
            "type": "string",
            "minLength": 8
          },
          "why": {
            "type": "string",
            "minLength": 12
          }
        }
      }
    },
    "kpis": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "description": "First 3 are core in this exact order: training_quality, volume_load, recovery_demand. Optional 1-2 extras after.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasoning",
          "id",
          "label_de",
          "value",
          "band"
        ],
        "properties": {
          "reasoning": {
            "type": "string",
            "minLength": 20
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,40}$",
            "description": "snake_case. First 3 must be: training_quality, volume_load, recovery_demand."
          },
          "label_de": {
            "type": "string",
            "minLength": 3,
            "maxLength": 40
          },
          "value": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "band": {
            "enum": [
              "above_usual",
              "steady",
              "below_usual"
            ]
          }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "reasoning"
      ],
      "properties": {
        "reasoning": {
          "type": "string",
          "minLength": 20
        },
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
