{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnomalyExplanationPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["observation_id", "period_key", "context", "hypotheses"],
  "properties": {
    "observation_id": { "type": "string" },
    "period_key": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "observation_text", "facts_window_size"],
      "properties": {
        "mode": { "enum": ["driver", "spike"] },
        "observation_text": { "type": "string", "minLength": 1, "maxLength": 800 },
        "metric": { "type": "string" },
        "ts_ms": { "type": "integer" },
        "facts_window_size": { "type": "integer", "minimum": 1, "maximum": 14 }
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factor", "strength", "rationale"],
        "properties": {
          "factor": { "type": "string", "minLength": 1, "maxLength": 60 },
          "strength": { "enum": ["strong", "moderate", "weak", "unlikely"] },
          "rationale": { "type": "string", "minLength": 1, "maxLength": 400 }
        }
      }
    },
    "model": { "type": "string" }
  }
}
