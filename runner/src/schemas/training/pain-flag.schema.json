{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pain-flag.schema.json",
  "title": "TrainingPainFlagV1",
  "description": "First-class pain/discomfort event. Structured (location_code + side) drives aggregation and recurrence alarms; free_text is verbatim user input for per-flag LLM zoom-in (echo-verbatim-or-omit; never paraphrased or grouped on).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "actual_session_id",
    "location_code",
    "side",
    "severity",
    "raised_at"
  ],
  "properties": {
    "schema_version": { "const": "training/pain_flag/v1" },
    "id": { "type": "number", "minimum": 1 },
    "actual_session_id": { "type": "string", "format": "uuid" },
    "exercise_id": { "type": ["string", "null"], "minLength": 1 },
    "set_log_id": { "type": ["number", "null"], "minimum": 1 },
    "location_code": { "$ref": "#/definitions/LocationCode" },
    "side": { "enum": ["left", "right", "bilateral", "n_a"] },
    "severity": { "enum": ["mild", "sharp"] },
    "free_text": {
      "type": ["string", "null"],
      "maxLength": 480,
      "description": "Verbatim user input. Carried into per-flag LLM zoom-in; never paraphrased; never grouped on."
    },
    "raised_at": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "LocationCode": {
      "enum": [
        "back",
        "shoulder",
        "elbow",
        "wrist",
        "thumb",
        "hip",
        "knee",
        "ankle",
        "foot",
        "neck",
        "head",
        "chest",
        "abdominal",
        "other"
      ],
      "description": "Closed, general body-region vocabulary. Extending requires a migration."
    }
  }
}
