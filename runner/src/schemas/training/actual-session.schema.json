{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "actual-session.schema.json",
  "title": "ActualSessionV1",
  "description": "A session the user has started or completed. May or may not correspond to a PlannedSession. Pi-owned (PULSE_ACTUAL_SESSION).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "period_key",
    "plan_version",
    "state",
    "started_at"
  ],
  "properties": {
    "schema_version": { "const": "training/actual_session/v1" },
    "id": { "type": "string", "format": "uuid" },
    "period_key": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Wake-date local key (Europe/Berlin), via runner period.ts."
    },
    "plan_version": { "type": "number", "minimum": 1 },
    "planned_session_id": { "type": ["number", "null"], "minimum": 1 },
    "session_template_id": { "type": ["string", "null"], "minLength": 1 },
    "deviation_reason": {
      "enum": ["user_choice", "recovery", "schedule", "other", null],
      "default": null
    },
    "state": { "enum": ["in_progress", "completed", "abandoned"] },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "subjective_energy": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
    "note": { "type": ["string", "null"], "maxLength": 480 },
    "wearable_workout_id": { "type": ["number", "null"] },
    "wearable_link_status": {
      "enum": ["none", "tentative", "confirmed", "manual"],
      "default": "none"
    },
    "wearable_link_resolved_at": { "type": ["string", "null"], "format": "date-time" },
    "last_edited_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
