{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bundle.schema.json",
  "title": "BundleManifestV2",
  "description": "Run manifest describing the lifecycle of a single pipeline run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "period_key",
    "timeframe",
    "run_id",
    "started_at",
    "updated_at",
    "pipeline_status",
    "model",
    "model_version",
    "runs",
    "timings"
  ],
  "properties": {
    "schema_version": { "const": "bundle/v2" },
    "period_key": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "timeframe": { "type": "string", "enum": ["daily", "weekly"] },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "started_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "pipeline_status": {
      "type": "string",
      "enum": ["running", "ok", "partial", "failed", "abstained", "live"]
    },
    "model": { "type": "string" },
    "model_version": { "type": "string" },
    "runs": {
      "type": "array",
      "items": { "$ref": "#/definitions/StageRecord" }
    },
    "timings": {
      "type": "object",
      "description": "Map of stage name -> duration in milliseconds.",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    }
  },
  "definitions": {
    "StageRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "started_at", "ended_at", "error"],
      "properties": {
        "stage": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ok", "partial", "failed", "skipped", "abstained"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "format": "date-time" }
          ]
        },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
