{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/runner/*": [
        "./runner/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "runner/src/analyzer/anomaly-explanation.ts",
    "runner/src/analyzer/anomaly-validator.ts",
    "runner/src/analyzer/explanation-cache.ts",
    "runner/src/analyzer/landing-candidates-core.ts",
    "runner/src/analyzer/landing-curator.ts",
    "runner/src/analyzer/landing-cache.ts",
    "runner/src/analyzer/screenshot-extractor.ts",
    "runner/src/v3/**/*.ts",
    "runner/src/facts/window.ts",
    "runner/src/facts/baselines.ts",
    "runner/src/facts/signal-quality.ts",
    "runner/src/rules/stats.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "runner",
    "_archive"
  ]
}
