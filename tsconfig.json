{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/runner/*": [
        "./runner/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "runner/src/analyzer/anomaly-explanation.ts",
    "runner/src/v3/**/*.ts",
    "runner/src/facts/window.ts",
    "runner/src/facts/baselines.ts",
    "runner/src/facts/signal-quality.ts",
    "runner/src/rules/stats.ts",
    "runner/src/jobs/cell.ts",
    "runner/src/jobs/queue.ts",
    "runner/src/jobs/queue-marker.ts",
    "runner/src/jobs/redis.ts",
    "runner/src/jobs/settings.ts",
    "runner/src/jobs/types.ts",
    "runner/src/clusters/index.ts",
    "runner/src/clusters/anomaly_explain/types.ts",
    "runner/src/clusters/weekly_recap/types.ts",
    "runner/src/clusters/morning_insight/types.ts",
    "runner/src/clusters/synthesis_v3/types.ts",
    "runner/src/v4/types.ts",
    "runner/src/v4/view-state/writer.ts",
    "runner/src/v4/view-state/reader.ts",
    "runner/src/v4/view-state/builder.ts",
    "runner/src/v4/slots/_registry.ts",
    "runner/src/v4/slots/night-review/types.ts",
    "runner/src/v4/slots/morning-briefing/types.ts",
    "runner/src/v4/slots/midday-check/types.ts",
    "runner/src/v4/slots/evening-review/types.ts",
    "runner/src/v4/slots/day-synthesis/types.ts",
    "runner/src/v4/slots/post-workout/types.ts",
    "runner/src/v4/slots/anomaly-explain/types.ts",
    "runner/src/v4/slots/week-synthesis/types.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "runner",
    "_archive"
  ]
}
